{
  "name": "htsyndicate-dashboard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "HTSyndicate internal command dashboard - works on desktop, mobile web, and as installable PWA",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:vercel": "vercel --prod",
    "electron": "electron .",
    "electron:build": "electron-builder",
    "desktop": "npm run build && electron ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "googleapis": "^171.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "vite-plugin-pwa": "^0.17.0"
  },
  "main": "electron.js",
  "build": {
    "appId": "com.htsyndicate.dashboard",
    "productName": "HTSyndicate",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron.js"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
